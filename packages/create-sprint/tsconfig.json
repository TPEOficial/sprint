{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": false,
        "sourceMap": false,
        "noImplicitAny": false,
        "types": [
            "node"
        ]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}